# Copy to .env and adjust as needed for local development.
# docker-compose.yml reads these via env_file/environment defaults already
# baked in, so .env is only needed to override them.

POSTGRES_USER=dnd
POSTGRES_PASSWORD=dnd
POSTGRES_DB=dnd5e

DATABASE_URL=postgres://dnd:dnd@postgres:5432/dnd5e?sslmode=disable
REDIS_ADDR=redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

GATEWAY_PORT=8080
FRONTEND_PORT=5173
